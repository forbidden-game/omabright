#!/usr/bin/env python3
# omabright: per-monitor brightness control for Hyprland (Omarchy-friendly)
#
# Design goals:
# - Brightness keys adjust monitor under the mouse cursor.
# - eDP/LVDS/DSI uses brightnessctl (real backlight).
# - External monitors prefer ddcutil (DDC/CI); cache + coalesce to avoid key-repeat lag.
#
# No third-party Python deps.

from __future__ import annotations

import argparse
import asyncio
import dataclasses
import json
import os
import re
import shlex
import shutil
import subprocess
import sys
import time
from pathlib import Path
from typing import Any, Optional


VERSION = "0.2.2"
CONNECTOR_RE = re.compile(r"^(?!card\d+-)[A-Za-z][A-Za-z0-9]*(?:-[A-Za-z0-9]+)*-\d+$")
SYSTEMD_SERVICE_TEMPLATE = """\
[Unit]
Description=Omabright daemon (per-monitor brightness for Hyprland)
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=simple
ExecStart=%h/.local/bin/omabright daemon
Restart=on-failure
RestartSec=1

[Install]
WantedBy=graphical-session.target
"""

HYPR_SIG_CACHE_TTL_S = 5.0
_HYPR_SIG_CACHE: Optional[str] = None
_HYPR_SIG_CACHE_AT = 0.0


def eprint(*args: object) -> None:
    print(*args, file=sys.stderr)


def clamp(v: int, lo: int, hi: int) -> int:
    return max(lo, min(hi, v))


def now_ms() -> int:
    return int(time.time() * 1000)


def xdg_config_home() -> Path:
    v = os.environ.get("XDG_CONFIG_HOME")
    if v:
        return Path(v)
    return Path.home() / ".config"


def xdg_cache_home() -> Path:
    v = os.environ.get("XDG_CACHE_HOME")
    if v:
        return Path(v)
    return Path.home() / ".cache"


def runtime_dir() -> Path:
    v = os.environ.get("XDG_RUNTIME_DIR")
    if v:
        return Path(v)
    return Path("/tmp")


def socket_path() -> Path:
    return runtime_dir() / "omabright.sock"


def default_config() -> dict[str, Any]:
    return {
        "step_percent": 5,
        "backlight_device": None,  # auto-detect
        "ddc_enabled": True,
        # If DDC/CI is unavailable for a given external monitor, fall back to
        # Hyprland's per-output SDR brightness (software dimming).
        "sdr_fallback_enabled": True,
        "sdr_min": 0.20,
        "sdr_max": 1.00,
        # Force mapping monitor name -> DDC bus number, e.g. {"HDMI-A-1": 5}
        "ddc_overrides": {},
        # Optional OSD. Supported: null, "notify-send", "swayosd"
        "osd": "swayosd",
        # If true, do not execute brightness changes; useful for debugging.
        "dry_run": False,
    }


def config_path() -> Path:
    return xdg_config_home() / "omabright" / "config.json"


def load_config() -> dict[str, Any]:
    cfg = default_config()
    p = config_path()
    try:
        data = json.loads(p.read_text(encoding="utf-8"))
        if isinstance(data, dict):
            cfg.update(data)
    except FileNotFoundError:
        pass
    except Exception as ex:
        eprint(f"[omabright] config read failed: {p}: {ex}")
    return cfg


def save_default_config() -> Path:
    p = config_path()
    p.parent.mkdir(parents=True, exist_ok=True)
    if p.exists():
        return p
    p.write_text(json.dumps(default_config(), indent=2, sort_keys=True) + "\n", encoding="utf-8")
    return p


def which(cmd: str) -> Optional[str]:
    return shutil.which(cmd)


def run_capture(cmd: list[str], timeout_s: float = 3.0, *, env: Optional[dict[str, str]] = None) -> str:
    # Intentionally uses subprocess (sync); should be fast for hyprctl/brightnessctl.
    out = subprocess.check_output(cmd, timeout=timeout_s, env=env)
    return out.decode(errors="replace")


def run_check(cmd: list[str], timeout_s: float = 5.0, *, env: Optional[dict[str, str]] = None) -> None:
    subprocess.check_call(cmd, timeout=timeout_s, env=env)


def guess_hyprland_instance_signature(force_refresh: bool = False) -> Optional[str]:
    global _HYPR_SIG_CACHE
    global _HYPR_SIG_CACHE_AT

    now = time.monotonic()
    if not force_refresh and _HYPR_SIG_CACHE and (now - _HYPR_SIG_CACHE_AT) <= HYPR_SIG_CACHE_TTL_S:
        return _HYPR_SIG_CACHE

    best_sig: Optional[str] = None
    best_mtime = -1.0
    hypr_dir = runtime_dir() / "hypr"
    try:
        for child in hypr_dir.iterdir():
            if not child.is_dir():
                continue
            sock = child / ".socket.sock"
            if not sock.exists():
                continue
            try:
                mtime = sock.stat().st_mtime
            except OSError:
                continue
            if mtime > best_mtime:
                best_mtime = mtime
                best_sig = child.name
    except FileNotFoundError:
        best_sig = None
    except Exception:
        best_sig = None

    _HYPR_SIG_CACHE = best_sig
    _HYPR_SIG_CACHE_AT = now
    return best_sig


def hyprctl_env(force_refresh: bool = False) -> dict[str, str]:
    env = os.environ.copy()
    if force_refresh or not env.get("HYPRLAND_INSTANCE_SIGNATURE"):
        sig = guess_hyprland_instance_signature(force_refresh=force_refresh)
        if sig:
            env["HYPRLAND_INSTANCE_SIGNATURE"] = sig
    return env


def run_hyprctl_capture(args: list[str], timeout_s: float = 3.0) -> str:
    cmd = ["hyprctl", *args]
    env1 = hyprctl_env(force_refresh=False)
    try:
        return run_capture(cmd, timeout_s=timeout_s, env=env1)
    except subprocess.CalledProcessError:
        # Retry once after forcing signature refresh. This avoids startup races
        # where systemd starts the daemon before HYPRLAND_INSTANCE_SIGNATURE is imported.
        env2 = hyprctl_env(force_refresh=True)
        if env2.get("HYPRLAND_INSTANCE_SIGNATURE") != env1.get("HYPRLAND_INSTANCE_SIGNATURE"):
            return run_capture(cmd, timeout_s=timeout_s, env=env2)
        raise


def run_hyprctl_check(args: list[str], timeout_s: float = 5.0) -> None:
    cmd = ["hyprctl", *args]
    env1 = hyprctl_env(force_refresh=False)
    try:
        run_check(cmd, timeout_s=timeout_s, env=env1)
    except subprocess.CalledProcessError:
        env2 = hyprctl_env(force_refresh=True)
        if env2.get("HYPRLAND_INSTANCE_SIGNATURE") != env1.get("HYPRLAND_INSTANCE_SIGNATURE"):
            run_check(cmd, timeout_s=timeout_s, env=env2)
            return
        raise


@dataclasses.dataclass(frozen=True)
class HyprMonitor:
    name: str
    description: str
    make: str
    model: str
    serial: str
    refresh_rate: float
    x: int
    y: int
    width: int
    height: int
    scale: float
    sdr_brightness: float
    sdr_saturation: float
    color_management_preset: str
    transform: int
    vrr: bool
    focused: bool

    def contains(self, px: int, py: int) -> bool:
        return (self.x <= px < self.x + self.width) and (self.y <= py < self.y + self.height)

    def is_internal(self) -> bool:
        # Common internal panel names.
        return bool(re.match(r"^(eDP|LVDS|DSI)\b", self.name))


def hypr_cursorpos() -> tuple[int, int]:
    s = run_hyprctl_capture(["cursorpos"]).strip()
    # e.g. "4783, 809"
    m = re.match(r"^\s*(\d+)\s*,\s*(\d+)\s*$", s)
    if not m:
        raise RuntimeError(f"unexpected hyprctl cursorpos output: {s!r}")
    return int(m.group(1)), int(m.group(2))


def hypr_monitors() -> list[HyprMonitor]:
    raw = run_hyprctl_capture(["-j", "monitors"], timeout_s=3.0)
    data = json.loads(raw)
    mons: list[HyprMonitor] = []
    if not isinstance(data, list):
        return mons
    for item in data:
        if not isinstance(item, dict):
            continue
        refresh = float(item.get("refreshRate") or 0.0)
        mons.append(
            HyprMonitor(
                name=str(item.get("name") or ""),
                description=str(item.get("description") or ""),
                make=str(item.get("make") or ""),
                model=str(item.get("model") or ""),
                serial=str(item.get("serial") or ""),
                refresh_rate=refresh,
                x=int(item.get("x") or 0),
                y=int(item.get("y") or 0),
                width=int(item.get("width") or 0),
                height=int(item.get("height") or 0),
                scale=float(item.get("scale") or 1.0),
                sdr_brightness=float(item.get("sdrBrightness") or 1.0),
                sdr_saturation=float(item.get("sdrSaturation") or 1.0),
                color_management_preset=str(item.get("colorManagementPreset") or ""),
                transform=int(item.get("transform") or 0),
                vrr=bool(item.get("vrr") or False),
                focused=bool(item.get("focused") or False),
            )
        )
    return mons


def pick_monitor_under_cursor(mons: list[HyprMonitor], cursor: tuple[int, int]) -> Optional[HyprMonitor]:
    cx, cy = cursor
    for m in mons:
        if m.contains(cx, cy):
            return m
    # Fallback: focused monitor
    for m in mons:
        if m.focused:
            return m
    return mons[0] if mons else None


def brightnessctl_detect_backlight_device() -> Optional[str]:
    # brightnessctl -m -l: "intel_backlight,backlight,25207,65%,38787"
    try:
        out = run_capture(["brightnessctl", "-m", "-l"], timeout_s=2.0)
    except Exception:
        return None
    for line in out.splitlines():
        parts = [p.strip() for p in line.split(",")]
        if len(parts) >= 2 and parts[1] == "backlight" and parts[0]:
            return parts[0]
    return None


def brightnessctl_get_percent(device: str) -> int:
    out = run_capture(["brightnessctl", "-m", "-d", device], timeout_s=2.0).strip()
    parts = [p.strip() for p in out.split(",")]
    if len(parts) < 4:
        raise RuntimeError(f"unexpected brightnessctl -m output: {out!r}")
    # parts[3] like "65%"
    m = re.match(r"^(\d+)%$", parts[3])
    if not m:
        raise RuntimeError(f"unexpected brightness percent: {parts[3]!r}")
    return int(m.group(1))


def brightnessctl_step(device: str, delta_percent: int, dry_run: bool) -> int:
    if delta_percent == 0:
        return brightnessctl_get_percent(device)
    sign = "+" if delta_percent > 0 else "-"
    val = abs(delta_percent)
    expr = f"{val}%{sign}"
    if dry_run:
        eprint(f"[omabright] dry_run: brightnessctl -d {device} set {expr}")
    else:
        run_check(["brightnessctl", "-d", device, "set", expr], timeout_s=3.0)
    return brightnessctl_get_percent(device)


def brightnessctl_set(device: str, percent: int, dry_run: bool) -> int:
    percent = clamp(percent, 0, 100)
    expr = f"{percent}%"
    if dry_run:
        eprint(f"[omabright] dry_run: brightnessctl -d {device} set {expr}")
    else:
        run_check(["brightnessctl", "-d", device, "set", expr], timeout_s=3.0)
    return brightnessctl_get_percent(device)


@dataclasses.dataclass
class DdcDisplay:
    bus: int
    connector: str
    monitor: str
    valid: bool
    raw_text: str


def ddcutil_available() -> bool:
    return which("ddcutil") is not None


def ddcutil_detect() -> list[DdcDisplay]:
    # Parse `ddcutil detect --brief` output (best-effort).
    out = run_capture(["ddcutil", "detect", "--brief"], timeout_s=6.0)
    blocks: list[str] = []
    cur: list[str] = []
    for line in out.splitlines():
        stripped = line.strip()
        if stripped.startswith("Display ") or stripped.startswith("Invalid display"):
            if cur:
                blocks.append("\n".join(cur))
            cur = [line]
        else:
            if cur:
                cur.append(line)
    if cur:
        blocks.append("\n".join(cur))

    displays: list[DdcDisplay] = []
    for b in blocks:
        header = b.splitlines()[0].strip() if b.splitlines() else ""
        valid = header.startswith("Display ")
        # Example lines:
        #   I2C bus:             /dev/i2c-5
        #   DRM connector:       card1-HDMI-A-1
        #   Monitor:             XMI:Mi Monitor:6730510000088
        bus_m = re.search(r"/dev/i2c-(\d+)", b)
        if not bus_m:
            continue
        bus = int(bus_m.group(1))
        connector = ""
        m = re.search(r"^\s*DRM connector:\s*(.+?)\s*$", b, flags=re.MULTILINE)
        if not m:
            m = re.search(r"^\s*DRM_connector:\s*(.+?)\s*$", b, flags=re.MULTILINE)
        if m:
            connector = m.group(1).strip()
            # e.g. card1-HDMI-A-1 -> HDMI-A-1
            m2 = re.match(r"^card\d+-(.+)$", connector)
            if m2:
                connector = m2.group(1)
        monitor = ""
        m = re.search(r"^\s*Monitor:\s*(.+?)\s*$", b, flags=re.MULTILINE)
        if m:
            monitor = m.group(1).strip()
        displays.append(DdcDisplay(bus=bus, connector=connector, monitor=monitor, valid=valid, raw_text=b))
    return displays


@dataclasses.dataclass
class DdcState:
    max_value: int
    current_value: int
    # desired percent [0,100]
    desired_percent: int
    last_set_ms: int
    worker_task: Optional[asyncio.Task]
    last_error: Optional[str]
    disabled_until_ms: int


def ddcutil_getvcp_10(bus: int) -> tuple[int, int]:
    # Returns (current, max).
    out = run_capture(["ddcutil", "--bus", str(bus), "getvcp", "10"], timeout_s=6.0)
    # Typical:
    # "VCP code 0x10 (Brightness): current value =    50, max value =   100"
    m = re.search(r"current value\s*=\s*(\d+)\s*,\s*max value\s*=\s*(\d+)", out)
    if not m:
        raise RuntimeError(f"unexpected ddcutil getvcp output: {out.strip()!r}")
    return int(m.group(1)), int(m.group(2))


def ddcutil_setvcp_10(bus: int, value: int, timeout_s: float = 6.0) -> None:
    run_check(["ddcutil", "--bus", str(bus), "setvcp", "10", str(value)], timeout_s=timeout_s)


class OmabrightDaemon:
    def __init__(self, cfg: dict[str, Any]):
        self.cfg = cfg
        self.step_percent = int(cfg.get("step_percent") or 5)
        self.dry_run = bool(cfg.get("dry_run") or False)
        self.osd = cfg.get("osd")

        self.backlight_device = cfg.get("backlight_device") or brightnessctl_detect_backlight_device()
        self.ddc_enabled = bool(cfg.get("ddc_enabled") or False)
        self.sdr_fallback_enabled = bool(cfg.get("sdr_fallback_enabled") or False)
        self.sdr_min = float(cfg.get("sdr_min") if cfg.get("sdr_min") is not None else 0.20)
        self.sdr_max = float(cfg.get("sdr_max") if cfg.get("sdr_max") is not None else 1.00)
        self.ddc_overrides: dict[str, Any] = cfg.get("ddc_overrides") or {}

        self.ddc_displays: list[DdcDisplay] = []
        self.ddc_by_connector: dict[str, DdcDisplay] = {}
        self.ddc_state: dict[int, DdcState] = {}
        self.ddc_sema = asyncio.Semaphore(1)  # avoid too much I2C concurrency

        self.cache_dir = xdg_cache_home() / "omabright"
        self.cache_dir.mkdir(parents=True, exist_ok=True)
        self.map_cache_path = self.cache_dir / "ddc_map.json"
        self.ddc_map: dict[str, int] = {}  # monitor name -> bus
        self._load_map_cache()

    def _load_map_cache(self) -> None:
        try:
            data = json.loads(self.map_cache_path.read_text(encoding="utf-8"))
            if isinstance(data, dict):
                out: dict[str, int] = {}
                for k, v in data.items():
                    if isinstance(k, str) and CONNECTOR_RE.match(k) and isinstance(v, int):
                        out[k] = v
                self.ddc_map = out
        except FileNotFoundError:
            pass
        except Exception as ex:
            eprint(f"[omabright] failed to read map cache: {self.map_cache_path}: {ex}")

    def _save_map_cache(self) -> None:
        try:
            self.map_cache_path.write_text(json.dumps(self.ddc_map, indent=2, sort_keys=True) + "\n", encoding="utf-8")
        except Exception as ex:
            eprint(f"[omabright] failed to write map cache: {self.map_cache_path}: {ex}")

    def _notify(self, monitor: str, percent: int) -> None:
        percent = clamp(int(percent), 0, 100)
        if self.osd is None:
            return
        if self.osd == "notify-send":
            try:
                subprocess.Popen(["notify-send", "Brightness", f"{monitor}: {percent}%"])
            except Exception:
                pass
            return
        if self.osd == "swayosd":
            if which("swayosd-client") is None:
                return
            # Progress is 0..1, but avoid exact 0 so the bar is visible.
            progress = percent / 100.0
            if progress <= 0.0:
                progress = 0.01
            try:
                subprocess.Popen(
                    [
                        "swayosd-client",
                        "--monitor",
                        monitor,
                        "--custom-icon",
                        "display-brightness",
                        "--custom-progress",
                        f"{progress:.2f}",
                        "--custom-progress-text",
                        f"{percent}%",
                    ]
                )
            except Exception:
                pass
            return

    async def refresh_ddc(self) -> dict[str, Any]:
        if not (self.ddc_enabled and ddcutil_available()):
            self.ddc_displays = []
            self.ddc_by_connector = {}
            return {"ddc_available": False, "displays": []}
        # detect can be slow; run in thread
        displays = await asyncio.to_thread(ddcutil_detect)
        self.ddc_displays = displays
        self.ddc_by_connector = {d.connector: d for d in displays if d.connector}
        # Update mapping cache from valid DRM connector names only.
        # Also prune stale keys and connectors known to be invalid on this path.
        invalid_connectors = {d.connector for d in displays if d.connector and not d.valid}
        self.ddc_map = {
            k: v for k, v in self.ddc_map.items() if CONNECTOR_RE.match(k) and k not in invalid_connectors
        }
        for d in displays:
            if d.valid and d.connector and CONNECTOR_RE.match(d.connector):
                self.ddc_map[d.connector] = d.bus
        self._save_map_cache()

        return {
            "ddc_available": True,
            "displays": [
                {"bus": d.bus, "connector": d.connector, "monitor": d.monitor, "valid": d.valid} for d in displays
            ],
        }

    def _resolve_ddc_bus(self, mon: HyprMonitor) -> Optional[int]:
        # Order:
        # 1) explicit overrides
        # 2) cached mapping
        # 3) heuristic match from latest detect
        name = mon.name
        disp = self.ddc_by_connector.get(name)
        if disp and not disp.valid:
            return None
        if name in self.ddc_overrides:
            try:
                return int(self.ddc_overrides[name])
            except Exception:
                return None
        if name in self.ddc_map:
            return self.ddc_map[name]
        # If we have a current detection snapshot, prefer mapping by connector name.
        for d in self.ddc_displays:
            if d.valid and d.connector and d.connector == name:
                self.ddc_map[name] = d.bus
                self._save_map_cache()
                return d.bus
        return None

    async def _ddc_ensure_state(self, bus: int) -> DdcState:
        st = self.ddc_state.get(bus)
        if st:
            # Retry after backoff window.
            if st.last_error and now_ms() >= st.disabled_until_ms:
                self.ddc_state.pop(bus, None)
            else:
                return st

        # Seed by reading current/max once.
        try:
            cur, mx = await asyncio.to_thread(ddcutil_getvcp_10, bus)
        except Exception as ex:
            st = DdcState(
                max_value=100,
                current_value=0,
                desired_percent=0,
                last_set_ms=0,
                worker_task=None,
                last_error=str(ex),
                disabled_until_ms=now_ms() + 60_000,
            )
            self.ddc_state[bus] = st
            return st

        st = DdcState(
            max_value=mx,
            current_value=cur,
            desired_percent=int(round(cur / mx * 100)) if mx > 0 else 0,
            last_set_ms=0,
            worker_task=None,
            last_error=None,
            disabled_until_ms=0,
        )
        self.ddc_state[bus] = st
        return st

    async def _ddc_worker(self, bus: int) -> None:
        while True:
            st = self.ddc_state.get(bus)
            if not st:
                return
            desired = st.desired_percent
            mx = st.max_value or 100
            value = clamp(int(round(mx * desired / 100)), 0, mx)

            if self.dry_run:
                eprint(f"[omabright] dry_run: ddcutil --bus {bus} setvcp 10 {value} ({desired}%)")
                st.current_value = value
                st.last_set_ms = now_ms()
            else:
                try:
                    async with self.ddc_sema:
                        await asyncio.to_thread(ddcutil_setvcp_10, bus, value)
                    st.current_value = value
                    st.last_set_ms = now_ms()
                    st.last_error = None
                    st.disabled_until_ms = 0
                except Exception as ex:
                    st.last_error = str(ex)
                    st.disabled_until_ms = now_ms() + 60_000
                    return

            # If desired changed while we were setting, loop again; else exit.
            await asyncio.sleep(0)  # let other requests update desired
            st2 = self.ddc_state.get(bus)
            if not st2 or st2.desired_percent == desired:
                return

    async def adjust_for_cursor(
        self,
        delta_percent: Optional[int],
        set_percent: Optional[int],
        *,
        monitor_name: Optional[str] = None,
    ) -> dict[str, Any]:
        cursor = hypr_cursorpos()
        mons = hypr_monitors()
        if monitor_name:
            mon = next((m for m in mons if m.name == monitor_name), None)
        else:
            mon = pick_monitor_under_cursor(mons, cursor)
        if not mon:
            return {"ok": False, "error": "no monitors", "monitor": monitor_name}

        if mon.is_internal():
            if not self.backlight_device:
                return {"ok": False, "error": "no backlight device found (brightnessctl -l)"}
            if set_percent is not None:
                newp = brightnessctl_set(self.backlight_device, set_percent, dry_run=self.dry_run)
            else:
                dp = int(delta_percent or 0)
                newp = brightnessctl_step(self.backlight_device, dp, dry_run=self.dry_run)
            self._notify(mon.name, newp)
            return {"ok": True, "monitor": mon.name, "backend": "backlight", "percent": newp}

        # external: prefer DDC/CI, else fall back to Hyprland SDR brightness
        if self.ddc_enabled and ddcutil_available():
            if not self.ddc_displays:
                await self.refresh_ddc()

            disp = self.ddc_by_connector.get(mon.name)
            if disp and not disp.valid:
                # `ddcutil detect` already told us this output doesn't do DDC/CI.
                # Avoid slow I2C timeouts on every keypress.
                pass
            else:
                bus = self._resolve_ddc_bus(mon)
                if bus is not None:
                    st_existing = self.ddc_state.get(bus)
                    if st_existing and st_existing.last_error and now_ms() < st_existing.disabled_until_ms:
                        # backoff
                        pass
                    else:
                        st = await self._ddc_ensure_state(bus)
                        if not st.last_error:
                            if set_percent is not None:
                                st.desired_percent = clamp(int(set_percent), 0, 100)
                            else:
                                dp = int(delta_percent or 0)
                                st.desired_percent = clamp(int(st.desired_percent + dp), 0, 100)

                            queued = False
                            if st.worker_task is None or st.worker_task.done():
                                st.worker_task = asyncio.create_task(self._ddc_worker(bus))
                                queued = True

                            curp = int(round(st.current_value / st.max_value * 100)) if st.max_value > 0 else 0
                            self._notify(mon.name, st.desired_percent)
                            return {
                                "ok": True,
                                "monitor": mon.name,
                                "backend": "ddc",
                                "bus": bus,
                                "current_percent": curp,
                                "desired_percent": st.desired_percent,
                                "queued": queued,
                                "last_error": st.last_error,
                            }

        if not self.sdr_fallback_enabled:
            if not self.ddc_enabled:
                return {"ok": False, "monitor": mon.name, "error": "ddc disabled and sdr fallback disabled"}
            if not ddcutil_available():
                return {"ok": False, "monitor": mon.name, "error": "ddcutil not installed and sdr fallback disabled"}
            return {"ok": False, "monitor": mon.name, "error": "ddc failed and sdr fallback disabled"}

        # SDR brightness fallback (software dimming)
        smin = float(self.sdr_min)
        smax = float(self.sdr_max)
        if smax < smin:
            smin, smax = smax, smin
        rng = max(0.0001, smax - smin)
        cur = float(mon.sdr_brightness)
        cur = max(smin, min(smax, cur))
        cur_percent = int(round((cur - smin) / rng * 100.0))
        if set_percent is not None:
            desired_percent = clamp(int(set_percent), 0, 100)
        else:
            desired_percent = clamp(int(cur_percent + int(delta_percent or 0)), 0, 100)
        new_val = smin + rng * (desired_percent / 100.0)
        await asyncio.to_thread(self._hypr_set_sdr_brightness, mon, new_val)
        self._notify(mon.name, desired_percent)
        return {
            "ok": True,
            "monitor": mon.name,
            "backend": "sdr",
            "current_percent": cur_percent,
            "desired_percent": desired_percent,
            "sdr_brightness": round(new_val, 3),
            "range": {"min": smin, "max": smax},
        }

    def _hypr_set_sdr_brightness(self, mon: HyprMonitor, value: float) -> None:
        # Keep other fields stable by applying current mode/pos/scale plus updated SDR brightness.
        mode = f"{mon.width}x{mon.height}@{mon.refresh_rate:.2f}"
        pos = f"{mon.x}x{mon.y}"
        scale = f"{mon.scale:.2f}"
        cm = mon.color_management_preset or "srgb"
        vrr = 1 if mon.vrr else 0
        spec = (
            f"{mon.name},{mode},{pos},{scale},"
            f"cm,{cm},vrr,{vrr},transform,{mon.transform},"
            f"sdrbrightness,{value:.2f},sdrsaturation,{mon.sdr_saturation:.2f}"
        )
        if self.dry_run:
            eprint(f"[omabright] dry_run: hyprctl keyword monitor {spec!r}")
            return
        run_hyprctl_check(["keyword", "monitor", spec], timeout_s=3.0)

    async def status(self, *, monitor_name: Optional[str] = None) -> dict[str, Any]:
        cursor = hypr_cursorpos()
        mons = hypr_monitors()
        if monitor_name:
            mon = next((m for m in mons if m.name == monitor_name), None)
        else:
            mon = pick_monitor_under_cursor(mons, cursor)
        if not mon:
            return {"ok": False, "error": "no monitors", "monitor": monitor_name}
        res: dict[str, Any] = {"ok": True, "cursor": {"x": cursor[0], "y": cursor[1]}, "monitor": mon.name}
        if mon.is_internal():
            if self.backlight_device:
                try:
                    res["backend"] = "backlight"
                    res["device"] = self.backlight_device
                    res["percent"] = brightnessctl_get_percent(self.backlight_device)
                except Exception as ex:
                    res["backend"] = "backlight"
                    res["error"] = str(ex)
            else:
                res["backend"] = "backlight"
                res["error"] = "no backlight device found"
            return res

        res["backend"] = "ddc"
        if not ddcutil_available():
            res["error"] = "ddcutil not installed"
            if self.sdr_fallback_enabled:
                res["backend"] = "sdr"
                res["sdr_brightness"] = mon.sdr_brightness
            return res

        if not self.ddc_displays:
            await self.refresh_ddc()
        disp = self.ddc_by_connector.get(mon.name)
        if disp and not disp.valid:
            if self.sdr_fallback_enabled:
                res["backend"] = "sdr"
                res["sdr_brightness"] = mon.sdr_brightness
                res["sdr_saturation"] = mon.sdr_saturation
                res["range"] = {"min": self.sdr_min, "max": self.sdr_max}
                return res
            res["error"] = "ddc unsupported on this connector path"
            return res
        bus = self._resolve_ddc_bus(mon)
        if bus is not None:
            st = await self._ddc_ensure_state(bus)
            if not st.last_error:
                res["bus"] = bus
                res["desired_percent"] = st.desired_percent
                res["current_percent"] = int(round(st.current_value / st.max_value * 100)) if st.max_value > 0 else 0
                res["last_error"] = st.last_error
                return res

        if self.sdr_fallback_enabled:
            res["backend"] = "sdr"
            res["sdr_brightness"] = mon.sdr_brightness
            res["sdr_saturation"] = mon.sdr_saturation
            res["range"] = {"min": self.sdr_min, "max": self.sdr_max}
            return res

        res["error"] = "ddc unavailable and sdr fallback disabled"
        return res

    async def list_monitors(self) -> dict[str, Any]:
        mons = hypr_monitors()
        out: list[dict[str, Any]] = []
        if self.ddc_enabled and ddcutil_available() and not self.ddc_displays:
            await self.refresh_ddc()
        for m in mons:
            item: dict[str, Any] = {
                "name": m.name,
                "description": m.description,
                "make": m.make,
                "model": m.model,
                "serial": m.serial,
                "refresh_rate": m.refresh_rate,
                "x": m.x,
                "y": m.y,
                "width": m.width,
                "height": m.height,
                "scale": m.scale,
                "internal": m.is_internal(),
            }
            if m.is_internal():
                item["backend"] = "backlight"
                item["device"] = self.backlight_device
            else:
                disp = self.ddc_by_connector.get(m.name) if (self.ddc_enabled and ddcutil_available()) else None
                if disp and not disp.valid:
                    bus = None
                else:
                    bus = self._resolve_ddc_bus(m) if (self.ddc_enabled and ddcutil_available()) else None
                if bus is not None:
                    item["backend"] = "ddc"
                    item["bus"] = bus
                else:
                    item["backend"] = "sdr" if self.sdr_fallback_enabled else "ddc"
                    item["sdr_brightness"] = m.sdr_brightness
            out.append(item)
        return {"ok": True, "monitors": out}

    async def reset_sdr(self) -> dict[str, Any]:
        mons = hypr_monitors()
        changed: list[str] = []
        if not mons:
            return {"ok": False, "error": "no monitors"}
        if not self.sdr_fallback_enabled:
            return {"ok": False, "error": "sdr fallback disabled"}
        target = float(self.sdr_max)
        for m in mons:
            if m.is_internal():
                continue
            try:
                await asyncio.to_thread(self._hypr_set_sdr_brightness, m, target)
                changed.append(m.name)
            except Exception:
                continue
        return {"ok": True, "changed": changed, "sdr_brightness": round(target, 3)}


async def daemon_main(cfg: dict[str, Any]) -> int:
    sock = socket_path()
    if sock.exists():
        try:
            sock.unlink()
        except Exception as ex:
            eprint(f"[omabright] failed to remove existing socket {sock}: {ex}")
            return 2

    daemon = OmabrightDaemon(cfg)

    async def handle_client(reader: asyncio.StreamReader, writer: asyncio.StreamWriter) -> None:
        try:
            line = await reader.readline()
            if not line:
                return
            req = json.loads(line.decode("utf-8", errors="replace"))
            if not isinstance(req, dict):
                resp = {"ok": False, "error": "invalid request"}
            else:
                cmd = str(req.get("cmd") or "")
                if cmd == "ping":
                    resp = {"ok": True, "version": VERSION}
                elif cmd == "refresh":
                    resp = await daemon.refresh_ddc()
                    resp["ok"] = True
                elif cmd == "status":
                    mon_name = req.get("monitor")
                    resp = await daemon.status(monitor_name=str(mon_name) if mon_name else None)
                elif cmd == "list":
                    resp = await daemon.list_monitors()
                elif cmd == "step":
                    direction = str(req.get("direction") or "")
                    step = int(req.get("step_percent") or daemon.step_percent)
                    mon_name = req.get("monitor")
                    mon_name_s = str(mon_name) if mon_name else None
                    if direction == "up":
                        resp = await daemon.adjust_for_cursor(delta_percent=step, set_percent=None, monitor_name=mon_name_s)
                    elif direction == "down":
                        resp = await daemon.adjust_for_cursor(delta_percent=-step, set_percent=None, monitor_name=mon_name_s)
                    else:
                        resp = {"ok": False, "error": "missing/invalid direction"}
                elif cmd == "set":
                    try:
                        val = int(req.get("value"))
                    except Exception:
                        resp = {"ok": False, "error": "missing/invalid value"}
                    else:
                        mon_name = req.get("monitor")
                        resp = await daemon.adjust_for_cursor(
                            delta_percent=None,
                            set_percent=val,
                            monitor_name=str(mon_name) if mon_name else None,
                        )
                elif cmd == "reset":
                    resp = await daemon.reset_sdr()
                else:
                    resp = {"ok": False, "error": f"unknown cmd: {cmd}"}
        except Exception as ex:
            resp = {"ok": False, "error": str(ex)}
        try:
            writer.write((json.dumps(resp, ensure_ascii=True) + "\n").encode("utf-8"))
            try:
                await writer.drain()
            except ConnectionResetError:
                # Client timed out or closed early.
                return
        finally:
            try:
                writer.close()
                await writer.wait_closed()
            except Exception:
                pass

    server = await asyncio.start_unix_server(handle_client, path=str(sock))
    # Refresh DDC mapping lazily; this can be slow on some setups.
    asyncio.create_task(daemon.refresh_ddc())
    # Restrict socket perms (best-effort). XDG_RUNTIME_DIR is per-user anyway.
    try:
        os.chmod(sock, 0o600)
    except Exception:
        pass

    eprint(f"[omabright] daemon listening on {sock}")
    async with server:
        await server.serve_forever()
    return 0


def client_request(payload: dict[str, Any], timeout_s: float = 0.8) -> dict[str, Any]:
    sock = socket_path()
    if not sock.exists():
        raise RuntimeError(f"daemon socket not found: {sock} (start with: omabright daemon)")

    # Keep client sync and tiny; keybindings should return fast.
    import socket as pysock

    s = pysock.socket(pysock.AF_UNIX, pysock.SOCK_STREAM)
    s.settimeout(timeout_s)
    try:
        s.connect(str(sock))
        s.sendall((json.dumps(payload, ensure_ascii=True) + "\n").encode("utf-8"))
        data = b""
        while not data.endswith(b"\n"):
            chunk = s.recv(4096)
            if not chunk:
                break
            data += chunk
        if not data:
            raise RuntimeError("no response from daemon")
        return json.loads(data.decode("utf-8", errors="replace"))
    finally:
        try:
            s.close()
        except Exception:
            pass


def install_files() -> None:
    # Install to ~/.local/bin and ~/.config/systemd/user
    src = Path(__file__).resolve()
    dst_bin = Path.home() / ".local" / "bin"
    dst_bin.mkdir(parents=True, exist_ok=True)
    dst = dst_bin / "omabright"
    # Copy, do not symlink (keeps it stable even if repo moves)
    dst.write_bytes(src.read_bytes())
    os.chmod(dst, 0o755)

    # Prefer the repo template when running from a checkout, but fall back to an
    # embedded template when running from an already-installed script.
    service_src = Path(__file__).resolve().parent.parent / "systemd" / "omabright.service"
    if service_src.exists():
        service_bytes = service_src.read_bytes()
    else:
        service_bytes = SYSTEMD_SERVICE_TEMPLATE.encode("utf-8")
    service_dst_dir = Path.home() / ".config" / "systemd" / "user"
    service_dst_dir.mkdir(parents=True, exist_ok=True)
    service_dst = service_dst_dir / "omabright.service"
    service_dst.write_bytes(service_bytes)

    print(f"installed: {dst}")
    print(f"installed: {service_dst}")
    print("next:")
    print("  systemctl --user daemon-reload")
    print("  systemctl --user enable --now omabright.service")


def main(argv: list[str]) -> int:
    p = argparse.ArgumentParser(prog="omabright", add_help=True)
    sub = p.add_subparsers(dest="subcmd", required=True)

    sub.add_parser("init", help="write default config if missing")
    sub.add_parser("install", help="install to ~/.local/bin and install systemd user service")
    sub.add_parser("daemon", help="run daemon (foreground)")

    sub.add_parser("ping", help="ping daemon")
    sub.add_parser("refresh", help="refresh ddcutil mapping cache")
    statusp = sub.add_parser("status", help="show target monitor under cursor and brightness")
    statusp.add_argument("--monitor", default=None, help="force a specific monitor (debug)")
    sub.add_parser("list", help="list hypr monitors and mapping")

    up = sub.add_parser("up", help="step up on monitor under cursor (uses config step_percent)")
    up.add_argument("--step", type=int, default=None, help="override step percent for this command")
    up.add_argument("--monitor", default=None, help="force a specific monitor (debug)")
    down = sub.add_parser("down", help="step down on monitor under cursor (uses config step_percent)")
    down.add_argument("--step", type=int, default=None, help="override step percent for this command")
    down.add_argument("--monitor", default=None, help="force a specific monitor (debug)")
    setp = sub.add_parser("set", help="set percent on monitor under cursor")
    setp.add_argument("percent", type=int)
    setp.add_argument("--monitor", default=None, help="force a specific monitor (debug)")
    sub.add_parser("reset", help="reset external monitors SDR brightness to sdr_max (software fallback only)")

    args = p.parse_args(argv)
    cfg = load_config()

    if args.subcmd == "init":
        path = save_default_config()
        print(str(path))
        return 0

    if args.subcmd == "install":
        install_files()
        return 0

    if args.subcmd == "daemon":
        try:
            asyncio.run(daemon_main(cfg))
            return 0
        except KeyboardInterrupt:
            return 0

    # client mode
    try:
        if args.subcmd == "ping":
            resp = client_request({"cmd": "ping"})
        elif args.subcmd == "refresh":
            resp = client_request({"cmd": "refresh"}, timeout_s=10.0)
        elif args.subcmd == "status":
            payload = {"cmd": "status"}
            if args.monitor:
                payload["monitor"] = args.monitor
            resp = client_request(payload, timeout_s=2.0)
        elif args.subcmd == "list":
            resp = client_request({"cmd": "list"}, timeout_s=2.0)
        elif args.subcmd == "up":
            step = args.step if args.step is not None else cfg.get("step_percent")
            payload = {"cmd": "step", "direction": "up", "step_percent": step}
            if args.monitor:
                payload["monitor"] = args.monitor
            resp = client_request(payload)
        elif args.subcmd == "down":
            step = args.step if args.step is not None else cfg.get("step_percent")
            payload = {"cmd": "step", "direction": "down", "step_percent": step}
            if args.monitor:
                payload["monitor"] = args.monitor
            resp = client_request(payload)
        elif args.subcmd == "set":
            payload = {"cmd": "set", "value": int(args.percent)}
            if args.monitor:
                payload["monitor"] = args.monitor
            resp = client_request(payload, timeout_s=2.0)
        elif args.subcmd == "reset":
            resp = client_request({"cmd": "reset"}, timeout_s=3.0)
        else:
            raise RuntimeError("unreachable")
    except Exception as ex:
        eprint(f"[omabright] {ex}")
        return 2

    # Human-friendly output by default.
    if args.subcmd in ("up", "down", "set"):
        if resp.get("ok"):
            mon = resp.get("monitor")
            backend = resp.get("backend")
            if backend == "backlight":
                print(f"{mon} {resp.get('percent')}%")
            elif backend == "ddc":
                print(f"{mon} {resp.get('desired_percent')}% (ddc bus {resp.get('bus')})")
            elif backend == "sdr":
                print(f"{mon} {resp.get('desired_percent')}% (sdr fallback)")
            else:
                print(json.dumps(resp, indent=2, sort_keys=True))
        else:
            eprint(json.dumps(resp, indent=2, sort_keys=True))
            return 1
    else:
        print(json.dumps(resp, indent=2, sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
